# If you change this file, the build WILL break. You've been warned.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{py,pyi}]
indent_style = space
indent_size = 4

[*.{rs}]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

[*.{c,h,cc,cpp,hpp}]
indent_style = tab
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[*.java]
indent_style = space
indent_size = 4

[*.rb]
indent_style = space
indent_size = 2

[*.pl,*.pm]
indent_style = space
indent_size = 4

[*.sh]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{css,scss,less}]
indent_style = space
indent_size = 2

[*.{html,htm}]
indent_style = space
indent_size = 2

[*.lua]
indent_style = space
indent_size = 2
